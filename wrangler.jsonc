{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cf-demo1",
	"main": ".open-next/worker.js",
	// Set current date
	"compatibility_date": "2026-02-22",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	// Your Cloudflare Account ID: Cloudflare Dashboard → Workers & Pages → Overview → Account ID
	"account_id": "5303b4fd7e98dd71905ec635471689fc",
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"services": [
		{
			// Required by @opennextjs/cloudflare for ISR/revalidation - must match "name" above
			"binding": "WORKER_SELF_REFERENCE",
			"service": "cf-demo1"
		}
	],
	"images": {
		"binding": "IMAGES"
	},
	"observability": {
		"logs": {
			"enabled": true,
			"invocation_logs": true
		}
	},
	"vars": {
		"DEPLOYMENT_PLATFORM": "cloudflare"
	},
	// --- Incremental Cache (R2) ---
	// Required for ISR/SSG caching
	"r2_buckets": [
		{
			"binding": "NEXT_INC_CACHE_R2_BUCKET",
			"bucket_name": "cf-demo1-r2"
		}
	],
	// --- Queue (Durable Objects) ---
	// Required for time-based revalidation (ISR)
	"durable_objects": {
		"bindings": [
			{
				"name": "NEXT_CACHE_DO_QUEUE",
				"class_name": "DOQueueHandler"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"DOQueueHandler"
			]
		}
	],
	// --- Tag Cache (D1) ---
	// Required for On-demand revalidation (revalidatePath/revalidateTag)
	// Create D1 database: npx wrangler d1 create my-workers-app-tag-cache
	// Then update the database_id below
	"d1_databases": [
		{
			"binding": "NEXT_TAG_CACHE_D1",
			"database_name": "cf-demo1-d1",
			"database_id": "95a48d8a-76ac-4fc2-ba12-0303121881bc"
		}
	],
	// If using Neon, Hyperdrive is not needed; comment out this section
  // If using Supabase or self-hosted Postgres, uncomment and configure per https://nexty.dev/docs/start-project/cf-workers
	 "hyperdrive": [
	 	{
	 		"binding": "HYPERDRIVE",
	 		"id": "ec811d6f40d24dd3b98c7e14288237cc",
	 		"localConnectionString": "postgresql://user_demo1:tN6wN9cE4wQ0eX9k@31.97.65.98:9876/db_demo1"
	 	}
	 ]
}
