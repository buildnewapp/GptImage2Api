{
  "models": {
    "video:bytedance-seedance-2": {
      "set": {
        "properties.input.properties.duration.minimum": 4,
        "properties.input.properties.duration.maximum": 15
      }
    },
    "video:bytedance-seedance-2-0-fast": {
      "set": {
        "properties.input.properties.duration.minimum": 4,
        "properties.input.properties.duration.maximum": 15
      }
    },
    "video:kling-3-0": {
      "replace": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "kling-3.0"
            ],
            "default": "kling-3.0",
            "examples": [
              "kling-3.0"
            ],
            "description": "The model name to use for generation. Required field.\n\n- Must be `kling-3.0` for this endpoint"
          },
          "input": {
            "type": "object",
            "properties": {
              "prompt": {
                "type": "string",
                "description": "Text prompt describing the video to generate."
              },
              "image_urls": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uri"
                },
                "description": "Optional first-frame or ending-frame reference images."
              },
              "sound": {
                "type": "boolean",
                "default": true,
                "description": "Whether to generate sound effects."
              },
              "duration": {
                "type": "string",
                "enum": [
                  "5",
                  "10"
                ],
                "default": "5",
                "description": "Video duration in seconds."
              },
              "aspect_ratio": {
                "type": "string",
                "enum": [
                  "16:9",
                  "9:16",
                  "1:1"
                ],
                "default": "16:9",
                "description": "Output aspect ratio."
              },
              "mode": {
                "type": "string",
                "enum": [
                  "std",
                  "pro"
                ],
                "default": "std",
                "description": "Generation mode."
              },
              "multi_shots": {
                "type": "boolean",
                "default": false,
                "description": "Enable multi-shot generation mode."
              }
            },
            "required": [
              "prompt"
            ]
          }
        }
      }
    }
  }
}
